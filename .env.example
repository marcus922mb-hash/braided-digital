# Publiczny adres produkcyjny bez ukośnika na końcu.
NEXT_PUBLIC_SITE_URL=https://web.ma-atelier.pl

# Resend — wysyłanie powiadomień e-mail po wysłaniu formularza wyceny.
# Dokumentacja: https://resend.com/docs/introduction
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=
NEXT_PUBLIC_APP_URL=https://web.ma-atelier.pl
APP_ENCRYPTION_KEY=

# ── Supabase ─────────────────────────────────────────────────────────────────
# Znajdziesz te wartości w Supabase Dashboard → Settings → API.
# NIGDY nie dodawaj SUPABASE_SERVICE_ROLE_KEY do kodu klienta!

# Project URL (publiczny — bezpieczny po stronie klienta)
NEXT_PUBLIC_SUPABASE_URL=

# Anon Key (publiczny — bezpieczny po stronie klienta, chroniony przez RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service Role Key (TYLKO serwer — nigdy nie eksponuj po stronie klienta!)
SUPABASE_SERVICE_ROLE_KEY=

# ── AI providers ─────────────────────────────────────────────────────────────
# Kolejność providerów oraz odporność routera.
AI_PROVIDER_ORDER=openrouter,cloudflare,gemini,groq,local
AI_TIMEOUT_MS=30000
AI_RETRY_COUNT=2
AI_RETRY_BASE_DELAY_MS=350

# Opcjonalne modele per zadanie: provider:model,provider:model
# AI_DEMO_GENERATION_MODELS=openrouter:openai/gpt-4o-mini,cloudflare:@cf/meta/llama-3.1-8b-instruct

# OpenRouter — generowanie treści demo po stronie serwera.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
# Lista modeli fallback rozdzielona przecinkami (nadpisuje OPENROUTER_MODEL).
OPENROUTER_MODELS=
OPENROUTER_APP_NAME=MA Atelier Studio

# Dodatkowi providerzy.
GEMINI_API_KEY=
GEMINI_MODELS=
GROQ_API_KEY=
GROQ_MODELS=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# Preferowana ścieżka: nasz Worker z natywnym bindingiem env.AI.
CLOUDFLARE_WORKERS_AI_URL=
CLOUDFLARE_WORKERS_AI_SECRET=
# Modele przeniesione z woo-saas-cloudflare; kolejność oznacza fallback.
CLOUDFLARE_MODELS=@cf/meta/llama-3.1-8b-instruct,@cf/meta/llama-3.3-70b-instruct-fp8-fast,@cf/meta/llama-3.1-70b-instruct,@cf/mistral/mistral-7b-instruct-v0.2

# Lokalny endpoint kompatybilny z OpenAI, np. http://127.0.0.1:11434/v1
LOCAL_AI_BASE_URL=
LOCAL_AI_API_KEY=
LOCAL_AI_MODELS=

# ── Biblioteki zdjęć ─────────────────────────────────────────────────────────
# Kolejność ma wpływ na preferencję wyników o podobnej jakości.
IMAGE_PROVIDER_ORDER=pexels,unsplash,pixabay
PEXELS_API_KEY=nEkvRwRdVjI0FMDFPPv8eUjXw2ErpaXxyzPDn3kk8d0AGzAVQrs3nkht
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=

# ── Publikacja (adaptery przygotowane, integracje do wdrożenia później) ───────
VERCEL_TOKEN=

# ── WordPress Headless ────────────────────────────────────────
# Klucz szyfrowania haseł Application Password (64 znaki hex = 32 bajty).
# Generuj: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NIGDY nie commituj prawdziwego klucza!
WORDPRESS_ENCRYPTION_KEY=
